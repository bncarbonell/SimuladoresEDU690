<script>
let selectedType = '';
let currentModule = 0;
let score = 0;
let moduleScores = [];
let answeredModules = {};

const typeLabels = {
  'ejecutiva': 'Audiencia ejecutiva (C-Suite)',
  'comercial': 'Audiencia comercial (clientes)',
  'educativa': 'Audiencia educativa (equipo/estudiantes)'
};

const modules = [
  { id: 'audiencia', name: 'Conocer la audiencia', icon: '👥' },
  { id: 'objetivo', name: 'Definir el objetivo', icon: '🎯' },
  { id: 'apertura', name: 'Apertura poderosa', icon: '🚀' },
  { id: 'mensajes', name: 'Mensajes clave', icon: '💬' },
  { id: 'diapositivas', name: 'Diseño de slides', icon: '🖼️' },
  { id: 'storytelling', name: 'Narrativa y storytelling', icon: '📖' },
  { id: 'presencia', name: 'Tono y presencia', icon: '🎭' },
  { id: 'humor', name: 'Uso del humor', icon: '😄' },
  { id: 'practica', name: 'Práctica y ensayo', icon: '🔄' },
  { id: 'cierre', name: 'Cierre memorable', icon: '🏁' },
];

function selectType(el, type) {
  document.querySelectorAll('.type-card').forEach(c => c.classList.remove('selected'));
  el.classList.add('selected');
  selectedType = type;
  document.getElementById('btn-start').disabled = false;
}

function startSim() {
  document.getElementById('screen-welcome').classList.remove('active');
  document.getElementById('screen-sim').classList.add('active');
  document.getElementById('header-type').textContent = typeLabels[selectedType];
  buildNav();
  buildAudience();
  loadModule(0);
}

function buildNav() {
  const nav = document.getElementById('module-nav');
  nav.innerHTML = modules.map((m, i) => `
    <button class="mod-tab ${i === 0 ? 'active' : 'locked'}" id="tab-${i}" onclick="tryGoModule(${i})">
      ${m.icon} ${m.name}
    </button>
  `).join('');
}

function tryGoModule(i) {
  if (i > currentModule && !answeredModules[currentModule]) return;
  if (i <= currentModule || answeredModules[i] !== undefined) {
    loadModule(i);
  }
}

function buildAudience() {
  const aud = document.getElementById('scene-audience');
  const colors = ['#7c8fa6','#8ba0b5','#6b7f94','#9bb0c5','#a0b4c8','#7c8fa6','#8ba0b5'];
  aud.innerHTML = colors.map(c => `
    <div class="saud">
      <div class="saud-head" style="background:${c}"></div>
      <div class="saud-body" style="background:${c}88"></div>
    </div>
  `).join('');
}

function updateMeters(atencion, credibilidad, conexion, retencion, emotion) {
  document.getElementById('m-atencion').style.width = atencion + '%';
  document.getElementById('m-credibilidad').style.width = credibilidad + '%';
  document.getElementById('m-conexion').style.width = conexion + '%';
  document.getElementById('m-retencion').style.width = retencion + '%';
  if (emotion) {
    const eb = document.getElementById('emotion-bubble');
    eb.style.display = 'block';
    eb.textContent = emotion;
    setTimeout(() => eb.style.display = 'none', 2500);
  }
}

function updateSlide(content) {
  document.getElementById('slide-content').innerHTML = content;
}

function addScore(pts) {
  score += pts;
  document.getElementById('score-display').textContent = score;
}

function loadModule(idx) {
  currentModule = idx;
  document.querySelectorAll('.mod-tab').forEach((t, i) => {
    t.classList.remove('active');
    if (i < idx) { t.classList.add('done'); t.classList.remove('locked'); }
    else if (i === idx) { t.classList.add('active'); t.classList.remove('locked','done'); }
    else if (answeredModules[i] !== undefined) { t.classList.remove('locked'); }
    else { t.classList.add('locked'); }
  });
  const pct = Math.round(((idx + 1) / modules.length) * 100);
  document.getElementById('progress-fill').style.width = pct + '%';
  document.getElementById('progress-label').textContent = `Módulo ${idx + 1} de ${modules.length}`;

  const renderers = [
    renderAudiencia, renderObjetivo, renderApertura, renderMensajes,
    renderDiapositivas, renderStorytelling, renderPresencia, renderHumor,
    renderPractica, renderCierre
  ];
  renderers[idx]();
}

function nextModule() {
  if (currentModule < modules.length - 1) {
    const next = currentModule + 1;
    document.querySelector(`#tab-${next}`).classList.remove('locked');
    loadModule(next);
  } else {
    showResults();
  }
}

// =============================================
// MODULE RENDERERS
// =============================================

function renderAudiencia() {
  updateSlide('<strong>¿Quién es tu audiencia?</strong><br><span style="font-size:10px; color:#64748b;">Conocer antes de hablar</span>');
  updateMeters(30, 40, 30, 30, '🤔');

  const typeData = {
    ejecutiva: {
      q: 'Vas a presentar ante el equipo directivo de una empresa (CEO, CFO, VP). ¿Cuál es tu primer paso estratégico?',
      choices: [
        { text: 'Investigar qué métricas y KPIs importan más a cada directivo presente', correct: true, fb: '¡Perfecto! Los ejecutivos piensan en términos de impacto, ROI y decisiones estratégicas. Conocer sus prioridades específicas te permite enfocar cada mensaje en lo que realmente les mueve.', tip: 'Consejo PRO: Pide una reunión previa de 10 minutos con el sponsor para entender el "mood" del comité.' },
        { text: 'Preparar una presentación muy detallada y técnica para demostrar profundidad', wrong: true, fb: 'Incorrecto. Los ejecutivos no tienen tiempo ni paciencia para el detalle técnico excesivo. Quieren síntesis, impacto y decisiones claras. Un exceso de detalle genera aburrimiento y pérdida de credibilidad.' },
        { text: 'Llegar con energía y confiar en tu capacidad de improvisar según las reacciones', wrong: true, fb: 'Incorrecto. La improvisación sin conocimiento previo es riesgosa ante ejecutivos. Ellos detectan inmediatamente cuando alguien no ha hecho la tarea. La preparación es no-negociable.' },
      ]
    },
    comercial: {
      q: 'Vas a presentar tu producto ante un potencial cliente. ¿Cuál es tu primer paso estratégico?',
      choices: [
        { text: 'Investigar los pain points, competidores actuales y el presupuesto disponible del cliente', correct: true, fb: '¡Exacto! En ventas, el conocimiento del cliente es poder. Saber qué le duele, qué alternativas considera y cuánto puede invertir te permite personalizar cada argumento y aumentar dramáticamente tu tasa de cierre.' },
        { text: 'Comenzar presentando todas las características y funcionalidades de tu producto', wrong: true, fb: 'Incorrecto. Este es el error más común en ventas. Los clientes no compran características, compran soluciones a sus problemas. Si hablas de ti mismo antes de entender al cliente, pierdes la atención.' },
        { text: 'Enviar el brochure por email para que el cliente llegue informado', wrong: true, fb: 'Incorrecto. El brochure sin contexto raramente genera interés real. La investigación previa te permite llegar con preguntas inteligentes y propuestas específicas, no genéricas.' },
      ]
    },
    educativa: {
      q: 'Vas a capacitar a un equipo de 20 personas en una nueva herramienta. ¿Cuál es tu primer paso?',
      choices: [
        { text: 'Evaluar el nivel de conocimiento previo y resistencia al cambio del grupo', correct: true, fb: '¡Correcto! En educación, el punto de partida del aprendiz determina todo. Conocer si son principiantes o avanzados, y si hay resistencia al cambio, te permite diseñar actividades, ejemplos y el ritmo adecuado.' },
        { text: 'Preparar una presentación estándar igual para todos los grupos que capacitas', wrong: true, fb: 'Incorrecto. El "copy-paste" de presentaciones sin personalización produce aprendizaje superficial. Cada grupo tiene contexto, nivel y motivaciones distintas que deben reflejarse en el diseño de la sesión.' },
        { text: 'Empezar directamente con los contenidos para aprovechar el tiempo al máximo', wrong: true, fb: 'Incorrecto. Saltar el diagnóstico inicial es uno de los errores más costosos. Sin saber dónde está el grupo, puedes hablar demasiado básico (aburrimiento) o demasiado avanzado (confusión y desconexión).' },
      ]
    }
  };

  const d = typeData[selectedType];
  const panel = document.getElementById('content-panel');
  panel.innerHTML = `
    <div class="module-header">
      <div class="module-tag">Módulo 1 — Conocer la audiencia</div>
      <h2 class="module-h2">👥 ¿A quién le hablas?</h2>
      <p class="module-p">${d.q}</p>
    </div>
    <div class="tip-box">
      <strong>Recuerda:</strong> Las mejores presentaciones no comienzan con slides, comienzan con preguntas. Cuanto más sabes de tu audiencia, más relevante y persuasivo serás.
    </div>
    <div class="choices-grid" id="choices-grid">
      ${d.choices.map((c, i) => `
        <button class="choice-btn" onclick="answerAudiencia(${i})" data-idx="${i}">
          <div class="choice-letter">${String.fromCharCode(65+i)}</div>
          <div class="choice-text">${c.text}</div>
        </button>
      `).join('')}
    </div>
    <div class="feedback-box" id="feedback-box"></div>
    <button class="btn-next" id="btn-next" onclick="nextModule()">Siguiente módulo →</button>
  `;

  window._moduleData = d.choices;
}

function answerAudiencia(idx) {
  if (answeredModules[0] !== undefined) return;
  const choices = window._moduleData;
  const ch = choices[idx];
  const btns = document.querySelectorAll('.choice-btn');
  btns.forEach((b, i) => {
    b.disabled = true;
    if (choices[i].correct) b.classList.add('correct');
    else if (choices[i].wrong) b.classList.add('wrong');
  });
  const fb = document.getElementById('feedback-box');
  fb.style.display = 'block';
  if (ch.correct) {
    fb.className = 'feedback-box correct';
    fb.innerHTML = `<div class="fb-title">✅ ¡Excelente decisión!</div><div class="fb-body">${ch.fb}</div>${ch.tip ? `<div class="fb-tip">💡 ${ch.tip}</div>` : ''}`;
    addScore(10); answeredModules[0] = 10;
    updateMeters(75, 80, 70, 65, '😊');
    updateSlide('<strong style="color:#16a34a">✓ Audiencia analizada</strong><br><span style="font-size:10px; color:#64748b;">Conocimiento = poder</span>');
  } else {
    fb.className = 'feedback-box wrong';
    fb.innerHTML = `<div class="fb-title">❌ Estrategia equivocada</div><div class="fb-body">${ch.fb}</div>`;
    answeredModules[0] = 0;
    updateMeters(25, 30, 25, 25, '😐');
    updateSlide('<strong style="color:#dc2626">Audiencia desconocida</strong><br><span style="font-size:10px; color:#64748b;">Presentación en riesgo</span>');
  }
  document.getElementById('btn-next').style.display = 'inline-block';
}

function renderObjetivo() {
  updateSlide('<strong>¿Cuál es tu objetivo?</strong><br><span style="font-size:10px; color:#64748b;">Define antes de diseñar</span>');

  const panel = document.getElementById('content-panel');
  panel.innerHTML = `
    <div class="module-header">
      <div class="module-tag">Módulo 2 — Objetivo de la presentación</div>
      <h2 class="module-h2">🎯 Define tu objetivo con precisión</h2>
      <p class="module-p">Selecciona el tipo de objetivo correcto para tu presentación y luego elige el objetivo SMART más efectivo según tu contexto.</p>
    </div>
    <div class="tip-box"><strong>El error más común:</strong> La mayoría de presentadores confunde "informar" con "persuadir". Un objetivo vago produce presentaciones vagas. Un objetivo específico produce resultados específicos.</div>
    <div class="info-grid" id="obj-type-grid">
      <div class="info-card" onclick="selectObjType(this,'informar')">
        <div class="ic-icon">📢</div>
        <div class="ic-title">Informar</div>
        <div class="ic-body">Transmitir datos, hechos, actualizaciones. La audiencia debe saber algo nuevo.</div>
      </div>
      <div class="info-card" onclick="selectObjType(this,'persuadir')">
        <div class="ic-icon">💡</div>
        <div class="ic-title">Persuadir</div>
        <div class="ic-body">Cambiar una creencia o actitud. La audiencia debe pensar distinto.</div>
      </div>
      <div class="info-card" onclick="selectObjType(this,'mover')">
        <div class="ic-icon">🚀</div>
        <div class="ic-title">Mover a la acción</div>
        <div class="ic-body">Generar un comportamiento concreto. La audiencia debe hacer algo.</div>
      </div>
      <div class="info-card" onclick="selectObjType(this,'inspirar')">
        <div class="ic-icon">✨</div>
        <div class="ic-title">Inspirar</div>
        <div class="ic-body">Generar emoción y propósito. La audiencia debe sentir algo.</div>
      </div>
    </div>
    <div class="feedback-box" id="obj-feedback" style="display:none;"></div>
    <button class="btn-next" id="btn-next" onclick="nextModule()" style="display:none;">Siguiente módulo →</button>
  `;
}

function selectObjType(el, type) {
  if (answeredModules[1] !== undefined) return;
  document.querySelectorAll('#obj-type-grid .info-card').forEach(c => c.classList.remove('selected'));
  el.classList.add('selected');

  const typeMatch = {
    ejecutiva: { best: 'mover', label: 'Mover a la acción' },
    comercial: { best: 'mover', label: 'Mover a la acción' },
    educativa: { best: 'informar', label: 'Informar + Persuadir' }
  };

  const fb = document.getElementById('obj-feedback');
  fb.style.display = 'block';
  const best = typeMatch[selectedType].best;

  const explanations = {
    informar: selectedType === 'educativa'
      ? { cls: 'correct', title: '✅ ¡Buena elección para contexto educativo!', body: 'En un contexto educativo, informar con claridad es fundamental. Aunque también querrás persuadir sobre la relevancia del contenido. Combina ambos: informa los hechos, persuade sobre su importancia.', tip: 'Objetivo SMART ejemplo: "Al finalizar la sesión, el 90% de los participantes sabrá usar las 3 funciones principales de la herramienta y podrá aplicarlas en su próximo proyecto."' }
      : { cls: 'neutral', title: '⚠️ Objetivo demasiado pasivo', body: 'Informar es útil pero insuficiente para una audiencia ejecutiva o comercial. Los ejecutivos y clientes necesitan ser movidos a tomar una decisión o acción. Solo informar no genera compromiso.', tip: 'Reformula: En lugar de "quiero que sepan sobre X", di "quiero que aprueben X" o "quiero que compren X".' },
