          <div class="choice-text">
            <strong>${c.t}</strong>
            <div style="font-size:12px; color:var(--text2); margin-top:3px; font-style:italic;">${c.d}</div>
          </div>
        </button>
      `).join('')}
    </div>
    <div class="feedback-box" id="cierre-feedback" style="display:none;"></div>
    <button class="btn-next" id="btn-next" onclick="showResults()" style="display:none; background:#16a34a;">
      Ver mis resultados finales 🏆
    </button>
  `;
  window._cierres = cierres;
}

function answerCierre(idx) {
  if (answeredModules[9] !== undefined) return;
  const c = window._cierres[idx];
  document.querySelectorAll('#cierre-grid .choice-btn').forEach((b, i) => {
    b.disabled = true;
    b.classList.add(window._cierres[i].q);
  });
  const fb = document.getElementById('cierre-feedback');
  fb.style.display = 'block';
  fb.className = 'feedback-box ' + c.q;
  const titles = { correct:'✅ ¡Cierre de alto impacto!', neutral:'⚠️ Cierre funcional', wrong:'❌ Cierre que no cierra' };
  fb.innerHTML = `<div class="fb-title">${titles[c.q]}</div><div class="fb-body">${c.fb}</div><div class="fb-tip">💡 ${c.tip}</div>`;

  if (c.q === 'correct') { addScore(10); answeredModules[9] = 10; updateMeters(95, 93, 95, 95, '🏆'); updateSlide('<strong style="color:#16a34a; font-size:11px">🏆 ¡Cierre poderoso!</strong><br><span style="font-size:10px; color:#334155">Impresión final inolvidable</span>'); }
  else if (c.q === 'neutral') { addScore(5); answeredModules[9] = 5; updateMeters(75, 78, 72, 76, '🙂'); updateSlide('<strong style="color:#d97706; font-size:11px">⚠ Cierre mejorable</strong><br><span style="font-size:10px; color:#334155">Funcional pero no memorable</span>'); }
  else { addScore(0); answeredModules[9] = 0; updateMeters(55, 58, 50, 54, '😕'); updateSlide('<strong style="color:#dc2626; font-size:11px">✗ Cierre débil</strong><br><span style="font-size:10px; color:#334155">Oportunidad perdida</span>'); }

  document.getElementById('btn-next').style.display = 'inline-block';
}

function showResults() {
  document.getElementById('screen-sim').classList.remove('active');
  document.getElementById('screen-results').classList.add('active');

  const pct = Math.min(Math.round((score / 100) * 100), 100);
  document.getElementById('final-score').textContent = score;

  let title, desc;
  if (score >= 85) { title = '🏆 ¡Presentador de élite!'; desc = 'Has demostrado dominar los 10 pilares de una presentación efectiva. Tu audiencia tendrá una experiencia memorable y estarás generando el impacto que buscas. Sigue practicando y seras imparable.'; }
  else if (score >= 65) { title = '⭐ ¡Sólido presentador profesional!'; desc = 'Tienes bases muy fuertes. Con algunos ajustes en los módulos donde perdiste puntos, llegarás al nivel de presentador de élite. La diferencia entre bueno y excelente es práctica deliberada.'; }
  else if (score >= 45) { title = '📈 Presentador en desarrollo'; desc = 'Tienes potencial real, pero hay áreas clave que necesitan trabajo. Revisa los módulos donde no obtuviste la máxima puntuación y practica esas técnicas específicamente. El crecimiento exponencial está cerca.'; }
  else { title = '🌱 Punto de partida poderoso'; desc = 'Toda gran habilidad comienza igual: desde cero con curiosidad. Vuelve a explorar cada módulo, aplica una técnica a la vez, y verás cómo cada presentación te convierte en un mejor comunicador. El camino está claro.'; }

  document.getElementById('results-title').textContent = title;
  document.getElementById('results-desc').textContent = desc;

  const badges = [];
  if (answeredModules[0] >= 10) badges.push({ icon:'🔍', name:'Investigador', desc:'Conoces tu audiencia' });
  if (answeredModules[2] >= 10) badges.push({ icon:'🚀', name:'Impacto inicial', desc:'Apertura poderosa' });
  if (answeredModules[4] >= 10) badges.push({ icon:'🖼️', name:'Diseño claro', desc:'Slides efectivos' });
  if (answeredModules[5] >= 8) badges.push({ icon:'📖', name:'Narrador', desc:'Storytelling maestro' });
  if (answeredModules[7] >= 10) badges.push({ icon:'😄', name:'Humor calibrado', desc:'Humor estratégico' });
  if (score >= 80) badges.push({ icon:'🏆', name:'Presentador élite', desc: `${score}/100 puntos` });

  document.getElementById('badges-row').innerHTML = badges.length > 0
    ? badges.map(b => `<div class="badge-item"><div class="bi-icon">${b.icon}</div><div class="bi-name">${b.name}</div><div class="bi-desc">${b.desc}</div></div>`).join('')
    : '<div style="font-size:13px; color:var(--text3)">Completa más módulos para ganar insignias</div>';
}

function restartSim() {
  score = 0; currentModule = 0; answeredModules = {}; selectedType = '';
  document.getElementById('score-display').textContent = '0';
  document.getElementById('screen-results').classList.remove('active');
  document.getElementById('screen-welcome').classList.add('active');
  document.querySelectorAll('.type-card').forEach(c => c.classList.remove('selected'));
  document.getElementById('btn-start').disabled = true;
}

function showTips() {
  window.open('https://www.google.com/search?q=presentaciones+efectivas+técnicas+profesionales', '_blank');
}
</script>
</body>
</html>
