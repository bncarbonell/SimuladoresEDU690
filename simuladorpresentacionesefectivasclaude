function shuffleArr(arr) {
  const a = [...arr]; for (let i = a.length-1; i > 0; i--) { const j = Math.floor(Math.random()*(i+1)); [a[i],a[j]] = [a[j],a[i]]; } return a;
}

function onDragStart(e) { window._dragSrc = e.currentTarget; e.dataTransfer.effectAllowed = 'move'; }
function onDragOver(e) { e.preventDefault(); e.dataTransfer.dropEffect = 'move'; }
function onDrop(e) {
  e.preventDefault();
  const src = window._dragSrc; const tgt = e.currentTarget;
  if (src === tgt) return;
  const list = document.getElementById('drag-list');
  const items = [...list.querySelectorAll('.drag-item')];
  const si = items.indexOf(src); const ti = items.indexOf(tgt);
  if (si < ti) list.insertBefore(src, tgt.nextSibling); else list.insertBefore(src, tgt);
  items.forEach((item, i) => item.querySelector('.drag-num').textContent = i+1);
}

