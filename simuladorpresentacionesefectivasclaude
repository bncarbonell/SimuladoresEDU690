<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Simulador de Presentaciones Efectivas</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --bg: #f0f4f8;
    --surface: #ffffff;
    --surface2: #f8fafc;
    --primary: #3b5bdb;
    --primary-light: #e8ecfd;
    --primary-dark: #2c44b0;
    --accent: #0ea5e9;
    --success: #16a34a;
    --success-light: #dcfce7;
    --danger: #dc2626;
    --danger-light: #fee2e2;
    --warning: #d97706;
    --warning-light: #fef3c7;
    --text: #1e293b;
    --text2: #475569;
    --text3: #94a3b8;
    --border: #e2e8f0;
    --radius: 12px;
    --shadow: 0 2px 12px rgba(0,0,0,0.08);
    --shadow-lg: 0 8px 32px rgba(0,0,0,0.14);
  }
  body {
    font-family: 'Segoe UI', system-ui, sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    overflow-x: hidden;
  }

  .screen { display: none; min-height: 100vh; }
  .screen.active { display: flex; flex-direction: column; }

  /* HEADER */
  .sim-header {
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    padding: 14px 24px;
    display: flex;
    align-items: center;
    gap: 16px;
    position: sticky; top: 0; z-index: 100;
  }
  .sim-logo {
    width: 36px; height: 36px; background: var(--primary);
    border-radius: 8px; display: flex; align-items: center; justify-content: center;
    color: white; font-size: 18px;
  }
  .sim-title { font-size: 16px; font-weight: 600; color: var(--text); }
  .sim-subtitle { font-size: 12px; color: var(--text3); }
  .progress-bar-wrap { flex: 1; max-width: 300px; }
  .progress-label { font-size: 11px; color: var(--text3); margin-bottom: 4px; }
  .progress-track { height: 6px; background: var(--border); border-radius: 3px; overflow: hidden; }
  .progress-fill { height: 100%; background: var(--primary); border-radius: 3px; transition: width 0.4s ease; }
  .score-badge {
    background: var(--primary-light); color: var(--primary);
    padding: 6px 14px; border-radius: 20px; font-size: 13px; font-weight: 600;
    margin-left: auto;
  }

  /* WELCOME SCREEN */
  .welcome-hero {
    flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center;
    padding: 40px 24px; text-align: center;
  }
  .stage-illustration {
    width: 340px; height: 220px; position: relative; margin-bottom: 32px;
  }
  .stage-bg {
    width: 100%; height: 100%; background: linear-gradient(160deg, #1e3a5f 0%, #0f2547 100%);
    border-radius: 20px; overflow: hidden; position: relative;
  }
  .stage-curtain-l, .stage-curtain-r {
    position: absolute; top: 0; width: 60px; height: 100%;
    background: linear-gradient(90deg, #6b1515, #8b1a1a);
  }
  .stage-curtain-l { left: 0; }
  .stage-curtain-r { right: 0; background: linear-gradient(270deg, #6b1515, #8b1a1a); }
  .stage-screen {
    position: absolute; top: 20px; left: 70px; right: 70px; height: 80px;
    background: #e2e8f0; border-radius: 6px;
    display: flex; align-items: center; justify-content: center;
    font-size: 11px; color: #475569; font-weight: 600;
  }
  .stage-podium {
    position: absolute; bottom: 20px; left: 50%; transform: translateX(-50%);
    width: 50px;
  }
  .podium-base {
    width: 50px; height: 12px; background: #4a5568; border-radius: 4px;
  }
  .podium-stem {
    width: 30px; height: 20px; background: #4a5568; border-radius: 4px;
    margin: 0 auto;
  }
  .presenter {
    position: absolute; bottom: 32px; left: 50%; transform: translateX(-50%);
    display: flex; flex-direction: column; align-items: center;
  }
  .pres-head {
    width: 22px; height: 22px; background: #f6c090; border-radius: 50%;
    border: 2px solid #e5a070;
  }
  .pres-body {
    width: 30px; height: 35px; background: #3b5bdb; border-radius: 4px 4px 0 0;
    margin-top: 2px;
  }
  .pres-arm-l, .pres-arm-r {
    position: absolute; width: 10px; height: 20px;
    background: #3b5bdb; border-radius: 4px; top: 24px;
  }
  .pres-arm-l { left: -8px; transform: rotate(20deg); }
  .pres-arm-r { right: -8px; transform: rotate(-20deg); }
  .audience-row {
    position: absolute; bottom: 0; left: 0; right: 0;
    display: flex; justify-content: space-around; padding: 0 8px 6px;
  }
  .aud-head {
    width: 14px; height: 14px; border-radius: 50%;
    background: #94a3b8;
  }
  .spotlight {
    position: absolute; top: 0; left: 50%; transform: translateX(-50%);
    width: 80px; height: 130px;
    background: radial-gradient(ellipse at top, rgba(255,240,100,0.18) 0%, transparent 80%);
    pointer-events: none;
  }
  .welcome-h1 {
    font-size: 28px; font-weight: 700; color: var(--text); margin-bottom: 12px;
  }
  .welcome-p {
    font-size: 15px; color: var(--text2); max-width: 480px; line-height: 1.7;
    margin-bottom: 28px;
  }
  .type-cards {
    display: flex; gap: 14px; margin-bottom: 32px; flex-wrap: wrap; justify-content: center;
  }
  .type-card {
    background: var(--surface); border: 2px solid var(--border);
    border-radius: var(--radius); padding: 16px 20px; cursor: pointer;
    transition: all 0.2s; min-width: 140px; text-align: center;
  }
  .type-card:hover { border-color: var(--primary); transform: translateY(-2px); box-shadow: var(--shadow); }
  .type-card.selected { border-color: var(--primary); background: var(--primary-light); }
  .type-card .tc-icon { font-size: 28px; margin-bottom: 6px; }
  .type-card .tc-name { font-size: 13px; font-weight: 600; color: var(--text); }
  .type-card .tc-desc { font-size: 11px; color: var(--text3); margin-top: 3px; }
  .btn-primary {
    background: var(--primary); color: white; border: none;
    padding: 14px 36px; border-radius: 10px; font-size: 16px; font-weight: 600;
    cursor: pointer; transition: all 0.2s; box-shadow: 0 4px 14px rgba(59,91,219,0.35);
  }
  .btn-primary:hover { background: var(--primary-dark); transform: translateY(-1px); }
  .btn-primary:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }

  /* MAIN SCENE */
  .scene-container {
    flex: 1; display: flex; flex-direction: column;
  }
  .scene-top {
    background: var(--surface); padding: 20px 24px 0;
    border-bottom: 1px solid var(--border);
  }
  .module-nav {
    display: flex; gap: 6px; overflow-x: auto; padding-bottom: 0;
  }
  .mod-tab {
    padding: 8px 14px; border-radius: 8px 8px 0 0; font-size: 12px;
    font-weight: 600; cursor: pointer; white-space: nowrap; border: none;
    background: transparent; color: var(--text3); transition: all 0.2s;
    border-bottom: 3px solid transparent; position: relative; top: 1px;
  }
  .mod-tab.active { color: var(--primary); border-bottom-color: var(--primary); background: var(--primary-light); }
  .mod-tab.done { color: var(--success); }
  .mod-tab.locked { opacity: 0.4; cursor: not-allowed; }

  .scene-body {
    flex: 1; display: flex; gap: 0;
  }

  /* LEFT: STAGE */
  .stage-panel {
    width: 320px; min-width: 280px; background: #1a2744;
    display: flex; flex-direction: column; align-items: center;
    padding: 24px 16px; gap: 12px; position: relative;
  }
  .stage-screen-big {
    width: 100%; aspect-ratio: 16/9; background: #f0f4ff;
    border-radius: 8px; overflow: hidden; border: 3px solid #0a1628;
    display: flex; align-items: center; justify-content: center;
    text-align: center; padding: 12px; position: relative;
  }
  .stage-screen-content { font-size: 12px; color: #334155; font-weight: 500; }
  .stage-scene-main {
    width: 100%; height: 130px; position: relative;
    background: #0f1f3d; border-radius: 8px; overflow: hidden;
  }
  .scene-floor { position: absolute; bottom: 0; width: 100%; height: 30px; background: #162035; }
  .scene-curtain-l { position: absolute; left: 0; top: 0; width: 28px; height: 100%; background: #6b1010; }
  .scene-curtain-r { position: absolute; right: 0; top: 0; width: 28px; height: 100%; background: #6b1010; }
  .scene-presenter {
    position: absolute; bottom: 20px; left: 50%; transform: translateX(-50%);
    display: flex; flex-direction: column; align-items: center; transition: all 0.3s;
  }
  .sp-head { width: 18px; height: 18px; background: #f6c090; border-radius: 50%; border: 2px solid #e5a070; }
  .sp-body { width: 26px; height: 32px; background: #3b5bdb; border-radius: 4px 4px 0 0; margin-top: 1px; }
  .sp-arm-l, .sp-arm-r { position: absolute; width: 8px; height: 18px; background: #3b5bdb; border-radius: 4px; top: 20px; }
  .sp-arm-l { left: -6px; transform: rotate(15deg); }
  .sp-arm-r { right: -6px; transform: rotate(-15deg); }
  .scene-audience {
    position: absolute; bottom: 0; left: 0; right: 0;
    display: flex; justify-content: space-around; padding: 0 8px;
  }
  .saud { display: flex; flex-direction: column; align-items: center; gap: 2px; }
  .saud-head { width: 12px; height: 12px; border-radius: 50%; }
  .saud-body { width: 14px; height: 10px; border-radius: 3px 3px 0 0; }
  .scene-spotlight {
    position: absolute; top: 0; left: 50%; transform: translateX(-50%);
    width: 70px; height: 100%;
    background: radial-gradient(ellipse at top, rgba(255,240,100,0.12) 0%, transparent 70%);
  }
  .emotion-bubble {
    position: absolute; top: 8px; right: 36px;
    background: white; border-radius: 12px; padding: 4px 8px;
    font-size: 14px; box-shadow: var(--shadow); display: none;
  }

  .stage-feedback {
    width: 100%; background: #0a1628; border-radius: 8px; padding: 12px;
  }
  .stage-feedback .sf-label { font-size: 10px; color: #64748b; font-weight: 600; text-transform: uppercase; letter-spacing: 0.8px; margin-bottom: 6px; }
  .stage-feedback .sf-meters { display: flex; flex-direction: column; gap: 6px; }
  .meter-row { display: flex; align-items: center; gap: 8px; }
  .meter-name { font-size: 10px; color: #94a3b8; min-width: 70px; }
  .meter-track { flex: 1; height: 5px; background: #1e3a5f; border-radius: 3px; overflow: hidden; }
  .meter-fill { height: 100%; border-radius: 3px; transition: width 0.5s ease; }
  .meter-fill.blue { background: #3b82f6; }
  .meter-fill.green { background: #22c55e; }
  .meter-fill.amber { background: #f59e0b; }
  .meter-fill.red { background: #ef4444; }

  /* RIGHT: CONTENT */
  .content-panel {
    flex: 1; padding: 24px; overflow-y: auto; background: var(--bg);
  }
  .module-header {
    margin-bottom: 20px;
  }
  .module-tag {
    display: inline-block; background: var(--primary-light); color: var(--primary);
    font-size: 11px; font-weight: 700; padding: 4px 10px; border-radius: 20px;
    text-transform: uppercase; letter-spacing: 0.8px; margin-bottom: 8px;
  }
  .module-h2 { font-size: 22px; font-weight: 700; color: var(--text); margin-bottom: 6px; }
  .module-p { font-size: 14px; color: var(--text2); line-height: 1.7; margin-bottom: 16px; }

  /* CHOICES */
  .choices-grid { display: flex; flex-direction: column; gap: 10px; }
  .choice-btn {
    background: var(--surface); border: 2px solid var(--border);
    border-radius: var(--radius); padding: 14px 16px; cursor: pointer;
    text-align: left; font-size: 14px; color: var(--text); font-family: inherit;
    transition: all 0.2s; display: flex; gap: 12px; align-items: flex-start;
    width: 100%;
  }
  .choice-btn:hover:not(:disabled) { border-color: var(--primary); background: var(--primary-light); }
  .choice-btn.correct { border-color: var(--success); background: var(--success-light); }
  .choice-btn.wrong { border-color: var(--danger); background: var(--danger-light); }
  .choice-btn.neutral { border-color: var(--warning); background: var(--warning-light); }
  .choice-btn:disabled { cursor: default; }
  .choice-letter {
    width: 26px; height: 26px; border-radius: 50%;
    background: var(--border); color: var(--text2); font-size: 12px;
    font-weight: 700; display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .choice-btn.correct .choice-letter { background: var(--success); color: white; }
  .choice-btn.wrong .choice-letter { background: var(--danger); color: white; }
  .choice-btn.neutral .choice-letter { background: var(--warning); color: white; }
  .choice-text { flex: 1; line-height: 1.5; }
  .choice-icon { font-size: 18px; flex-shrink: 0; }

  /* FEEDBACK BOX */
  .feedback-box {
    margin-top: 16px; border-radius: var(--radius); padding: 16px 18px;
    display: none; animation: fadeIn 0.3s ease;
  }
  .feedback-box.correct { background: var(--success-light); border-left: 4px solid var(--success); }
  .feedback-box.wrong { background: var(--danger-light); border-left: 4px solid var(--danger); }
  .feedback-box.neutral { background: var(--warning-light); border-left: 4px solid var(--warning); }
  .feedback-box .fb-title { font-size: 14px; font-weight: 700; margin-bottom: 4px; }
  .feedback-box.correct .fb-title { color: var(--success); }
  .feedback-box.wrong .fb-title { color: var(--danger); }
  .feedback-box.neutral .fb-title { color: var(--warning); }
  .feedback-box .fb-body { font-size: 13px; color: var(--text2); line-height: 1.6; }
  .feedback-box .fb-tip {
    margin-top: 8px; font-size: 12px; font-weight: 600; color: var(--primary);
    padding-top: 8px; border-top: 1px solid rgba(0,0,0,0.06);
  }

  /* NEXT BTN */
  .btn-next {
    margin-top: 20px; background: var(--primary); color: white; border: none;
    padding: 12px 28px; border-radius: 10px; font-size: 14px; font-weight: 600;
    cursor: pointer; transition: all 0.2s; display: none;
  }
  .btn-next:hover { background: var(--primary-dark); }

  /* SLIDE DESIGNER */
  .slide-designer { display: flex; flex-direction: column; gap: 16px; }
  .slide-preview-area {
    background: #1e293b; border-radius: var(--radius); padding: 16px;
    display: flex; gap: 12px; flex-wrap: wrap;
  }
  .slide-option {
    flex: 1; min-width: 160px; aspect-ratio: 4/3;
    border-radius: 8px; overflow: hidden; cursor: pointer;
    border: 3px solid transparent; transition: all 0.2s; position: relative;
  }
  .slide-option:hover { border-color: var(--accent); transform: scale(1.02); }
  .slide-option.selected { border-color: var(--success); }
  .slide-option.wrong { border-color: var(--danger); }
  .slide-label {
    position: absolute; bottom: 0; left: 0; right: 0;
    background: rgba(0,0,0,0.6); color: white; font-size: 10px;
    font-weight: 600; padding: 4px 6px; text-align: center;
  }

  /* CHECKLIST */
  .checklist { display: flex; flex-direction: column; gap: 8px; }
  .check-item {
    display: flex; align-items: flex-start; gap: 12px; background: var(--surface);
    border: 1px solid var(--border); border-radius: 10px; padding: 12px 14px;
    cursor: pointer; transition: all 0.2s;
  }
  .check-item:hover { border-color: var(--primary); background: var(--primary-light); }
  .check-item.checked { border-color: var(--success); background: var(--success-light); }
  .check-box {
    width: 22px; height: 22px; border: 2px solid var(--border);
    border-radius: 6px; flex-shrink: 0; display: flex; align-items: center;
    justify-content: center; transition: all 0.2s;
  }
  .check-item.checked .check-box {
    background: var(--success); border-color: var(--success); color: white;
    font-size: 12px;
  }
  .check-text { font-size: 13px; color: var(--text); line-height: 1.5; flex: 1; }
  .check-text strong { display: block; font-weight: 600; margin-bottom: 2px; }
  .check-text span { color: var(--text2); }

  /* STORYTELLING TIMELINE */
  .story-arc {
    background: var(--surface); border-radius: var(--radius); padding: 16px;
    margin-bottom: 16px;
  }
  .arc-steps {
    display: flex; gap: 0; align-items: stretch; margin: 12px 0;
    border-radius: 8px; overflow: hidden;
  }
  .arc-step {
    flex: 1; padding: 10px 8px; text-align: center; cursor: pointer;
    border: none; font-family: inherit; font-size: 12px; font-weight: 600;
    transition: all 0.2s; position: relative;
  }
  .arc-step::after {
    content: ''; position: absolute; right: -10px; top: 50%;
    transform: translateY(-50%);
    border-left: 10px solid currentColor;
    border-top: 20px solid transparent; border-bottom: 20px solid transparent;
    z-index: 1;
  }
  .arc-step:last-child::after { display: none; }

  /* DRAG & DROP ORDER */
  .drag-list { display: flex; flex-direction: column; gap: 8px; }
  .drag-item {
    background: var(--surface); border: 2px solid var(--border);
    border-radius: 10px; padding: 12px 14px; cursor: grab;
    display: flex; align-items: center; gap: 10px; font-size: 13px;
    transition: all 0.2s; user-select: none;
  }
  .drag-item:hover { border-color: var(--primary); }
  .drag-item.dragging { opacity: 0.5; cursor: grabbing; }
  .drag-handle { font-size: 16px; color: var(--text3); }
  .drag-num {
    width: 24px; height: 24px; background: var(--primary-light); color: var(--primary);
    border-radius: 50%; font-size: 11px; font-weight: 700;
    display: flex; align-items: center; justify-content: center;
  }

  /* TONO SLIDER */
  .tone-slider-wrap { margin: 16px 0; }
  .tone-labels { display: flex; justify-content: space-between; font-size: 11px; color: var(--text3); margin-bottom: 6px; }
  input[type=range].tone-range {
    width: 100%; height: 8px; -webkit-appearance: none; appearance: none;
    background: linear-gradient(90deg, #3b5bdb, #0ea5e9, #16a34a);
    border-radius: 4px; outline: none; cursor: pointer;
  }
  input[type=range].tone-range::-webkit-slider-thumb {
    -webkit-appearance: none; width: 22px; height: 22px;
    border-radius: 50%; background: white; border: 3px solid var(--primary);
    cursor: pointer; box-shadow: 0 2px 6px rgba(0,0,0,0.2);
  }

  /* HUMOR CARDS */
  .humor-cards { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
  .humor-card {
    background: var(--surface); border: 2px solid var(--border);
    border-radius: var(--radius); padding: 14px; cursor: pointer;
    transition: all 0.2s; text-align: center; font-size: 13px;
    color: var(--text);
  }
  .humor-card:hover { border-color: var(--primary); transform: translateY(-1px); }
  .humor-card .hc-emoji { font-size: 28px; margin-bottom: 6px; }
  .humor-card .hc-name { font-weight: 700; font-size: 13px; margin-bottom: 3px; }
  .humor-card .hc-desc { font-size: 11px; color: var(--text3); line-height: 1.4; }
  .humor-card.good { border-color: var(--success); background: var(--success-light); }
  .humor-card.bad { border-color: var(--danger); background: var(--danger-light); }
  .humor-card.ok { border-color: var(--warning); background: var(--warning-light); }

  /* RESULTS */
  .results-screen {
    flex: 1; display: flex; flex-direction: column; align-items: center;
    justify-content: center; padding: 40px 24px; text-align: center;
  }
  .score-circle {
    width: 140px; height: 140px; border-radius: 50%;
    border: 8px solid var(--primary); display: flex; flex-direction: column;
    align-items: center; justify-content: center; margin-bottom: 24px;
    background: var(--primary-light);
  }
  .score-num { font-size: 40px; font-weight: 800; color: var(--primary); }
  .score-label { font-size: 12px; color: var(--text3); font-weight: 600; }
  .results-h2 { font-size: 26px; font-weight: 700; margin-bottom: 10px; }
  .results-p { font-size: 15px; color: var(--text2); max-width: 460px; margin-bottom: 28px; line-height: 1.7; }
  .badges-row { display: flex; gap: 12px; flex-wrap: wrap; justify-content: center; margin-bottom: 28px; }
  .badge-item {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 12px; padding: 12px 16px; min-width: 120px;
    text-align: center;
  }
  .badge-item .bi-icon { font-size: 24px; margin-bottom: 4px; }
  .badge-item .bi-name { font-size: 12px; font-weight: 700; color: var(--text); }
  .badge-item .bi-desc { font-size: 11px; color: var(--text3); }
  .btn-restart {
    background: white; border: 2px solid var(--primary); color: var(--primary);
    padding: 12px 28px; border-radius: 10px; font-size: 15px; font-weight: 600;
    cursor: pointer; margin-left: 10px; transition: all 0.2s;
  }
  .btn-restart:hover { background: var(--primary); color: white; }

  @keyframes fadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: none; } }
  @keyframes pulse { 0%,100% { transform: scale(1); } 50% { transform: scale(1.05); } }
  .pulse { animation: pulse 1s ease infinite; }

  .tip-box {
    background: linear-gradient(135deg, #667eea15, #764ba215);
    border: 1px solid #667eea30; border-radius: var(--radius);
    padding: 12px 14px; margin-bottom: 16px; font-size: 13px; color: var(--text2);
    line-height: 1.6;
  }
  .tip-box strong { color: var(--primary); }

  .stat-row { display: flex; gap: 12px; margin-bottom: 16px; flex-wrap: wrap; }
  .stat-card {
    flex: 1; min-width: 100px; background: var(--surface);
    border: 1px solid var(--border); border-radius: 10px; padding: 12px 14px;
    text-align: center;
  }
  .stat-val { font-size: 22px; font-weight: 700; color: var(--primary); }
  .stat-name { font-size: 11px; color: var(--text3); margin-top: 2px; }

  .info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 16px; }
  .info-card {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 10px; padding: 14px; cursor: pointer; transition: all 0.2s;
  }
  .info-card:hover { border-color: var(--primary); transform: translateY(-1px); }
