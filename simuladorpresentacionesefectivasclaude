function selectSlide(el, idx) {
  if (answeredModules[4] !== undefined) return;
  const s = window._slides[idx];
  el.classList.toggle('selected');

  if (window._slideSelections.includes(idx)) {
    window._slideSelections = window._slideSelections.filter(i => i !== idx);
    el.classList.remove('correct','wrong');
  } else {
    window._slideSelections.push(idx);
    el.classList.add(s.quality === 'correct' ? 'correct' : s.quality === 'wrong' ? 'wrong' : 'selected');
  }

  if (window._slideSelections.length >= 2) {
    const fb = document.getElementById('slide-feedback');
    fb.style.display = 'block';
    const goodSelected = window._slideSelections.filter(i => window._slides[i].quality === 'correct').length;
    const badSelected = window._slideSelections.filter(i => window._slides[i].quality === 'wrong').length;

    let cls, title, body;
    if (goodSelected >= 2 && badSelected === 0) {
      cls = 'correct'; title = '✅ ¡Excelente criterio de diseño!';
      body = 'Seleccionaste los slides mejor diseñados: el slide visual con datos clave y el slide de dato único impactante. Ambos aplican el principio de "una idea por slide" y están diseñados para impactar en segundos.';
      addScore(10); answeredModules[4] = 10; updateMeters(85, 88, 80, 85, '😍');
    } else if (goodSelected >= 1 && badSelected === 0) {
      cls = 'neutral'; title = '👍 Buen instinto';
      body = 'Seleccionaste al menos un slide bien diseñado. Los slides A y D son los más efectivos por su claridad y foco en un único mensaje visual poderoso.';
      addScore(6); answeredModules[4] = 6; updateMeters(70, 75, 65, 70, '🙂');
    } else {
      cls = 'wrong'; title = '⚠️ Revisa tu criterio';
      body = 'Incluiste slides con problemas de diseño. El slide B (exceso de texto) es uno de los errores más comunes y más dañinos para la retención de mensajes.';
      addScore(3); answeredModules[4] = 3; updateMeters(45, 50, 40, 45, '😬');
    }

    fb.className = 'feedback-box ' + cls;
    const firstGood = window._slides.find(s2 => s2.quality === 'correct');
    fb.innerHTML = `<div class="fb-title">${title}</div><div class="fb-body">${body}</div>${firstGood ? `<div class="fb-tip">💡 ${firstGood.tip}</div>` : ''}`;
    updateSlide('<strong style="color:#16a34a; font-size:11px">✓ Diseño optimizado</strong><br><span style="font-size:10px">Claridad visual máxima</span>');
    document.getElementById('btn-next').style.display = 'inline-block';
  }
}

